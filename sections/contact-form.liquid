{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="contact page-width page-width--narrow section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank -%}
      <h2 class="title title-wrapper--no-top-margin inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.heading }}
      </h2>
    {%- else -%}
      <h2 class="visually-hidden">{{ 'templates.contact.form.title' | t }}</h2>
    {%- endif -%}
    {%- liquid
      assign contact_form_class = 'isolate'
      if settings.animations_reveal_on_scroll
        assign contact_form_class = 'isolate scroll-trigger animate--slide-in'
      endif
    -%}
    {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}
      {%- if form.posted_successfully? -%}
        <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
          {% render 'icon-success' %}
          {{ 'templates.contact.form.post_success' | t }}
        </h2>
      {%- elsif form.errors -%}
        <div class="form__message">
          <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
            {% render 'icon-error' %}
            {{ 'templates.contact.form.error_heading' | t }}
          </h2>
        </div>
        <ul class="form-status-list caption-large" role="list">
          <li>
            <a href="#ContactForm-email" class="link">
              {{ form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email }}
            </a>
          </li>
        </ul>
      {%- endif -%}
     <input
            type="hidden"
            name="contact[Wedding Event Favors Inquiry Form]"
          >
          {% comment %}
            <!-- Container for error message -->
            <div class='contact__form-error-message'>
              <div class='xo-form-error'>
                {% render 'icon', name: 'error' %}
                <div class='xo-form-error__message'>Message is invalid.</div>
              </div>
            </div>
          {% endcomment %}

          <xo-grid class="xo-contact__input">
            <xo-animate xo-cascade style="--lg: 6; --md: 12; --sm:12; --xs: 12">
              <div class="xo-contact__first-name">
                {% assign first_name_id = 'first-name--' | append: section.id %}
                {% assign nameLabel = 'First *' %}
                {% render 'field-input',
                  type: 'text',
                  name: 'contact[first_name]',
                  value: form.first_name,
                  label: nameLabel,
                  id: first_name_id
                %}
              </div>
            </xo-animate>
            <xo-animate xo-cascade style="--lg: 6; --md: 12; --sm:12; --xs: 12">
              <div class="xo-contact__last-name">
                {% assign last_name_id = 'last-name--' | append: section.id %}
                {% assign nameLabel = 'Last Name *' %}
                {% render 'field-input',
                  type: 'text',
                  name: 'contact[last_name]',
                  value: form.last_name,
                  label: nameLabel,
                  id: last_name_id
                %}
              </div>
            </xo-animate>
          </xo-grid>
          <xo-grid class="xo-contact__input">
            <!-- Email -->
            <xo-animate xo-cascade style="--lg: 6; --md: 6; --sm:12; --xs:12">
              <div class="xo-contact__email xo-contact__email1">
                {% assign email_id = 'email--' | append: section.id %}
                {% assign emailLabel = 'Email Address *' %}
                {% render 'field-input',
                  type: 'email',
                  name: 'contact[email]',
                  value: form.email,
                  label: emailLabel,
                  required: true,
                  id: email_id
                %}
              </div>
            </xo-animate>

            <!-- Phone -->
            <xo-animate xo-cascade style="--lg: 6; --md: 6; --sm:12; --xs:12">
              <div class="xo-contact__custom-field">
                <input
                  type="tel"
                  name="contact[phone]"
                  placeholder="Phone Number *"
                  required
                  class="xo-input-custom xo-field-input"
                >
              </div>
            </xo-animate>
          </xo-grid>

          {% comment %}
            <xo-animate xo-cascade style="--lg: 12; --md: 12; --sm:12; --xs: 12">
              <div class="xo-contact__subject">
                <div class="xo-contact__subject-input">
                  {% assign subject_id = 'subject--' | append: section.id %}
                  {% assign subjectLabel = 'Delivery Address *' %}
                  {% render 'field-input',
                    type: 'tel',
                    name: 'Delivery Address',
                    value: form.subject,
                    label: subjectLabel,
                    id: subject_id
                  %}
                </div>
              </div>
            </xo-animate>
          {% endcomment %}
          <xo-animate xo-cascade style="--lg: 12; --md: 12; --sm:12; --xs: 12">
            <div class="xo-contact__message xo-contact__message1">
              <div class="xo-contact__message-input">
                {% assign message_id = 'message--' | append: section.id %}
                {% assign messageLabel = 'Delivery Address *' %}
                {% render 'field-input',
                  name: 'contact[Delivery Address]',
                  value: form.body,
                  label: messageLabel,
                  required: true,
                  id: message_id
                %}
              </div>
            </div>
          </xo-animate>
          {% render 'space', spacing_dt: '8', spacing_mb: '8' %}
          <xo-animate xo-cascade style="--lg: 12; --md: 12; --sm:12; --xs: 12">
            <div class="xo-contact__event-date">
              <div class="xo-contact__event-date-input">
                {% assign event_date_id = 'event-date--' | append: section.id %}

                {% render 'field-input',
                  type: 'date',
                  name: 'contact[event_date]',
                  label: 'Event Date',
                  required: true,
                  id: event_date_id
                %}
              </div>
            </div>
          </xo-animate>
          <xo-animate xo-cascade style="--lg: 12; --md: 12; --sm:12; --xs: 12">
            {% assign nameLabelt = 'Type of Event' %}
            <div class="xo-select-wrapper xo-contact__custom-field xo-contact__custom-field1">
              <select name="contact[event_type]" class="xo-input-custom xo-select-custom">
                <option value="" disabled selected>{{ nameLabelt }}</option>

                {% assign event_types = section.settings.event_types | split: ',' %}

                {% for type in event_types %}
                  <option value="{{ type | strip }}">{{ type | strip }}</option>
                {% endfor %}
              </select>
            </div>
          </xo-animate>

          <xo-animate xo-cascade style="--lg: 12; --md: 12; --sm:12; --xs: 12">
            {% assign eventDateLabel1 = 'Estimated Guest Count *' %}
            <div class="xo-contact__custom-field xo-select-wrapper xo-select-wrapper-c">
              <select name="contact[guest_count]" required class="xo-input-custom xo-select-custom">
                <option value="" disabled selected>{{ eventDateLabel1 }}</option>

                {% assign guest_counts = section.settings.guest_counts | split: ',' %}

                {% for count in guest_counts %}
                  <option value="{{ count | strip }}">{{ count | strip }}</option>
                {% endfor %}
              </select>
            </div>
          </xo-animate>
          <xo-animate xo-cascade style="--lg: 12; --md: 12; --sm:12; --xs: 12;">
            {% assign FavorsLabel = 'Which Favors Are You Interested In?' %}

            <div class="xo-contact__custom-field">
              <p class="xo-field-label">{{ FavorsLabel }}</p>
              {% assign favor_options = section.settings.favor_options | split: ',' %}

              <div class="xo-checkbox-group">
                {% for option in favor_options %}
                  <label class="xo-checkbox-item">
                    <input
                      type="checkbox"
                      name="contact[favors]"
                      value="{{ option | strip }}"
                      class="favor-checkbox"
                      {% if forloop.first %}
                        checked
                      {% endif %}
                    >
                    <span>{{ option | strip }}</span>
                  </label>
                {% endfor %}
              </div>
            </div>
          </xo-animate>

          {% render 'space', spacing_dt: '8', spacing_mb: '8' %}
          <xo-animate xo-cascade style="--lg: 12; --md: 12; --sm:12; --xs: 12">
            <div class="xo-contact__message">
              <div class="xo-contact__message-input">
                {% assign message_id = 'message--' | append: section.id %}
                {% assign messageLabel = 'Tell Us About Your Vision' %}
                {% render 'field-textarea',
                  name: 'contact[Tell Us About Your Vision]',
                  value: form.body,
                  label: messageLabel,
                  id: message_id
                %}
              </div>
            </div>
          </xo-animate>
    
      <div class="contact__button">
        <button type="submit" class="button">
          {{ 'templates.contact.form.send' | t }}
        </button>
      </div>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.contact-form.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Contact form",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "event_types",
      "label": "Event Types (comma separated)",
      "default": "Wedding, Bridal/Baby Shower, Corporate Event, Other"
    },
    {
      "type": "text",
      "id": "guest_counts",
      "label": "Estimated Guest Count Options (comma separated)",
      "default": "50, 100, 150, 200+"
    },
    {
      "type": "text",
      "id": "favor_options",
      "label": "Favors Options (comma separated)",
      "default": "Signature Raw Honey Jars, Handcrafted Honey Soaps, Gourmet Coffee Beans, Artisanal Tea Blends, Curated Gift Boxes"
    },
    
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact-form.presets.name"
    }
  ]
}
{% endschema %}
